{
  "name": "raven-tui",
  "version": "0.1.0",
  "private": true,
  "description": "Raven native TUI (Ink + React). See ../docs/openspec/changes/tui-fork-hermes-import/.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npm run build --prefix packages/hermes-ink && tsx --watch src/entry.tsx",
    "demo": "npm run build --prefix packages/hermes-ink && tsx src/demo/gallery.tsx",
    "demo:watch": "npm run build --prefix packages/hermes-ink && tsx --watch src/demo/gallery.tsx",
    "start": "tsx src/entry.tsx",
    "build": "node scripts/build.mjs",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "fmt": "prettier --write 'src/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}'",
    "fix": "npm run lint:fix && npm run fmt",
    "pretest": "npm run build --prefix packages/hermes-ink",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:rpc": "node scripts/gen-rpc-types.mjs",
    "lint:rpc": "node scripts/gen-rpc-types.mjs --check"
  },
  "dependencies": {
    "@hermes/ink": "file:./packages/hermes-ink",
    "@nanostores/react": "^1.1.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "nanostores": "^1.2.0",
    "react": "^19.2.4",
    "unicode-animations": "^1.0.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@eslint/js": "^9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "~0.27.0",
    "eslint": "^9",
    "eslint-plugin-perfectionist": "^5",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-unused-imports": "^4",
    "globals": "^16",
    "ink-testing-library": "^4.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "zod-validation-error": "^4.0.2"
  }
}
